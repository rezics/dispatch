{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "#/*": ["./*"]
    }
  },
  "include": ["src", "prisma"]
}
